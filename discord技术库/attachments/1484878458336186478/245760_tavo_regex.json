  {
    "id": "a7a0108d-0e3b-4e4a-b47e-54cf9b52520b",
    "scriptName": "角色状态栏",
    "findRegex": "/(?:^|\\n)((?:[*]*【\\s*主要角色当前状态\\s*】[*]*[\\s\\S]*?[*]*【\\s*主要角色状态结束\\s*】[*]*\\s*)+)/g",
    "replaceString": "<div class=\"x-root\" onclick=\"event.stopPropagation()\"><style>.x-root{font-family:'Microsoft YaHei',sans-serif;font-size:13px;margin:10px 0;line-height:1.5}.x-c{background:#1e2129;border:2px solid #444;border-radius:10px;overflow:hidden;box-shadow:0 5px 15px rgba(0,0,0,.5);display:none}.x-h{display:flex;background:#151515;border-bottom:1px solid #333}.x-tab{flex:1;padding:12px 5px;text-align:center;cursor:pointer;color:#888;font-weight:bold;font-size:12px;border-right:1px solid #333;transition:.2s;white-space:nowrap;overflow:hidden}.x-tab:hover,.x-tab.act{background:#333;color:#fff}.x-b{padding:15px 20px;background:rgba(0,0,0,.2)}.x-r{display:flex;border-bottom:1px solid rgba(255,255,255,.05);padding:4px 0}.x-k{color:#999;min-width:65px;font-weight:bold}.x-v{color:#eee;flex:1}.x-msg{margin-top:10px;padding:8px 12px;background:rgba(0,0,0,.3);border-left:3px solid #666;font-style:italic;color:#ccc;border-radius:0 4px 4px 0}</style><div class=\"x-raw\" style=\"display:none\">$1</div><div class=\"x-c\"><div class=\"x-h\"></div><div class=\"x-b\"><div class=\"x-r\"><span class=\"x-k\">🕒 时间</span><span class=\"x-v v1\"></span></div><div class=\"x-r\"><span class=\"x-k\">📍 地点</span><span class=\"x-v v2\"></span></div><div class=\"x-r\"><span class=\"x-k\">👥 交互</span><span class=\"x-v v3\"></span></div><div class=\"x-r\"><span class=\"x-k\">🧘 姿势</span><span class=\"x-v v4\"></span></div><div class=\"x-r\"><span class=\"x-k\">👕 服饰</span><span class=\"x-v v5\"></span></div><div class=\"x-r\"><span class=\"x-k\">💖 状态</span><span class=\"x-v v6\"></span></div><div class=\"x-r\"><span class=\"x-k\">💗 友谊</span><span class=\"x-v v7\"></span></div><div class=\"x-r\"><span class=\"x-k\">🌡️ 兴奋</span><span class=\"x-v v8\"></span></div><div class=\"x-msg\">💭 <span class=\"v9\"></span></div></div></div><img src=\"x\" style=\"display:none\" onerror=\"try{var r=this.parentNode,raw=r.querySelector('.x-raw').innerText,ui=r.querySelector('.x-c'),tb=r.querySelector('.x-h'),bd=r.querySelector('.x-b'),d=[],reg=/[*]*【\\s*主要角色当前状态\\s*】[*]*\\s*角色标识[:：]\\s*(.*?)\\s*图标[:：]\\s*(.*?)\\s*颜色[:：]\\s*(.*?)\\s*背景[:：]\\s*(.*?)\\s*🕒\\s*时间[:：]\\s*(.*?)\\s*📍\\s*地点[:：]\\s*(.*?)\\s*👥\\s*交互对象[:：]\\s*(.*?)\\s*🧘\\s*姿势[:：]\\s*(.*?)\\s*👕\\s*服饰[:：]\\s*(.*?)\\s*💖\\s*状态[:：]\\s*(.*?)\\s*💗\\s*好感度[:：]\\s*(.*?)\\s*🌡️\\s*兴奋度[:：]\\s*(.*?)\\s*💭\\s*当前心声[:：]\\s*(.*?)\\s*[*]*【\\s*主要角色状态结束\\s*】[*]*\\s*/g,m;while(m=reg.exec(raw))d.push({n:m[1],i:m[2],c:m[3],bg:m[4],t:m[5],l:m[6],u:m[7],p:m[8],ub:m[9],lb:m[10],fv:m[11],ex:m[12],th:m[13]});if(d.length){ui.style.display='block';var set=function(i){var o=d[i];bd.querySelector('.v1').innerText=o.t;bd.querySelector('.v2').innerText=o.l;bd.querySelector('.v3').innerText=o.u;bd.querySelector('.v4').innerText=o.p;bd.querySelector('.v5').innerText=o.ub;bd.querySelector('.v6').innerText=o.lb;bd.querySelector('.v7').innerText=o.fv;bd.querySelector('.v8').innerText=o.ex;bd.querySelector('.v9').innerText=o.th;bd.style.background=o.bg;ui.style.borderColor=o.c;bd.querySelector('.x-msg').style.borderLeftColor=o.c;Array.from(tb.children).forEach(function(t,idx){t.style.color=idx===i?o.c:'#888';t.style.background=idx===i?'#222':''})};tb.innerHTML='';d.forEach(function(o,i){var t=document.createElement('div');t.className='x-tab';t.innerText=o.i+' '+o.n;t.onclick=function(e){e.stopPropagation();set(i)};tb.appendChild(t)});set(0)}}catch(e){console.error(e)}this.remove()\"></div>\n",
