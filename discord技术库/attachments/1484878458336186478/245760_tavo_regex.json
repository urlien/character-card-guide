    "replaceString": "<div style=\"position: fixed; right: 15px; top: 50%; transform: translateY(-50%); z-index: 99999;\" id=\"teapot-draggable-container-1721558234000\" onmousedown=\"event.stopPropagation();var el=this,r=el.getBoundingClientRect();el.style.transform='none';el.style.right='';el.style.left=r.left+'px';el.style.top=r.top+'px';el.dataset.d='true';el.dataset.x=event.clientX-r.left;el.dataset.y=event.clientY-r.top;\" onmousemove=\"var el=this;if(el.dataset.d=='true'){el.style.left=(event.clientX-parseFloat(el.dataset.x))+'px';el.style.top=(event.clientY-parseFloat(el.dataset.y))+'px';}\" onmouseup=\"this.dataset.d='false';\" onmouseleave=\"this.dataset.d='false';\" ontouchstart=\"event.stopPropagation();var el=this,r=el.getBoundingClientRect();el.style.transform='none';el.style.right='';el.style.left=r.left+'px';el.style.top=r.top+'px';el.dataset.d='true';var touch=event.touches[0];el.dataset.x=touch.clientX-r.left;el.dataset.y=touch.clientY-r.top;\" ontouchmove=\"event.preventDefault();var el=this;if(el.dataset.d=='true'){var touch=event.touches[0];el.style.left=(touch.clientX-parseFloat(el.dataset.x))+'px';el.style.top=(touch.clientY-parseFloat(el.dataset.y))+'px';}\" ontouchend=\"this.dataset.d='false';\">\n  <div style=\"width: 30px; height: 30px; border-radius: 50%; background-color: #0077B6; border: 1px solid #88CCEE; cursor: pointer; text-align: center; line-height: 30px; font-weight: bold; color: #88CCEE; box-shadow: 0 0 8px #88CCEE;\" onclick=\"event.stopPropagation();var menu=this.nextElementSibling;menu.style.display=(menu.style.display=='block'?'none':'block');\">⚙️</div>\n  <div style=\"position: absolute; right: 40px; top: -5px; display: none; flex-direction: column; gap: 5px; white-space: nowrap;\">\n    <div style=\"padding: 8px 12px; background-color: rgba(10, 25, 47, 0.85); border: 1px solid #0077B6; border-radius: 5px; cursor: pointer; color: #88CCEE; backdrop-filter: blur(5px);\" data-value=\"[请你结合过往剧情和作者设定来描述场景，输出不少于3400tokens，不要重复用语