    "findRegex": "/基础侧边框/",
    "replaceString": "<div class=\"teapot-pose-sidebar-right\" onclick=\"event.stopPropagation();\">\n<div class=\"teapot-pose-trigger-right\" onclick=\"var p=this.nextElementSibling;p.style.display=p.style.display==='none'?'flex':'none'\">特化库</div>\n<div class=\"teapot-pose-bubble-right\" style=\"display:none;\" onclick=\"event.stopPropagation();var t=event.target;if(t.classList.contains('teapot-pose-btn-right')){var a=document.querySelector('.chat .chat-bottom .uni-textarea .chat-input-scope textarea');if(a){a.value=a.value+t.getAttribute('data-text');a.dispatchEvent(new Event('input'))}}\">\n<div class=\"teapot-pose-close\" onclick=\"this.parentElement.style.display='none'\">×</div>\n<div class=\"teapot-pose-tabs\">\n<div class=\"teapot-pose-tab teapot-tab-active\" onclick=\"event.stopPropagation();var tabs=this.parentElement.children;var groups=this.parentElement.nextElementSibling.children;for(var i=0;i&lt;tabs.length;i++){tabs[i].classList.remove('teapot-tab-active');groups[i].style.display='none'};this.classList.add('teapot-tab-active');groups[0].style.display='flex'\">姿势特化</div>\n<div class=\"teapot-pose-tab\" onclick=\"event.stopPropagation();var tabs=this.parentElement.children;var groups=this.parentElement.nextElementSibling.children;for(var i=0;i&lt;tabs.length;i++){tabs[i].classList.remove('teapot-tab-active');groups[i].style.display='none'};this.classList.add('teapot-tab-active');groups[1].style.display='flex'\">玩法特化</div>\n<div class=\"teapot-pose-tab\" onclick=\"event.stopPropagation();var tabs=this.parentElement.children;var groups=this.parentElement.nextElementSibling.children;for(var i=0;i&lt;tabs.length;i++){tabs[i].classList.remove('teapot-tab-active');groups[i].style.display='none'};this.classList.add('teapot-tab-active');groups[2].style.display='flex'\">道具一</div>\n<div class=\"teapot-pose-tab\" onclick=\"event.stopPropagation();var tabs=this.parentElement.children;var groups=this.parentElement.nextElementSibling.children;for(var i=0;i&lt;tabs.length;i++){tabs[i].classList.remove('teapot-tab-active');groups[i].style.display='none'};this.classList.add('teapot-tab-active');groups[3].style.display='flex'\">道具二</div>\n</div>\n<div class=\"teapot-pose-content\">\n<div class=\"teapot-pose-group\" style=\"display:flex;\">\n<div class=\"teapot-pose-btn-right\" data-text=\"【抱头式特化】\">抱头式</div><div class=\"teapot-pose-btn-right\" data-text=\"【老汉推车特化】\">推车位</div><div class=\"teapot-pose-btn-right\" data-text=\"【打桩特化】\">打桩</div>\n<div class=\"teapot-pose-btn-right\" data-text=\"【乘骑位特化】\">乘骑位</div><div class=\"teapot-pose-btn-right\" data-text=\"【后入式特化】\">后入式</div><div class=\"teapot-pose-btn-right\" data-text=\"【传教士特化】\">传教士</div>\n<div class=\"teapot-pose-btn-right\" data-text=\"【侧入式特化】\">侧入式</div><div class=\"teapot-pose-btn-right\" data-text=\"【站立式特化】\">站立式</div><div class=\"teapot-pose-btn-right\" data-text=\"【69式特化】\">69式</div>\n<div class=\"teapot-pose-btn-right\" data-text=\"【站立后入特化】\">站立后入</div><div class=\"teapot-pose-btn-right\" data-text=\"【把尿体位特化】\">把尿式</div><div class=\"teapot-pose-btn-right\" data-text=\"【逆打桩特化】\">逆打桩</div>\n</div>\n<div class=\"teapot-pose-group\" style=\"display:none;\">\n<div class=\"teapot-pose-btn-right\" data-text=\"【丝袜足交特化】\">丝袜足</div><div class=\"teapot-pose-btn-right\" data-text=\"【深喉特化】\">深喉</div><div class=\"teapot-pose-btn-right\" data-text=\"【乳交特化】\">乳交</div>\n<div class=\"teapot-pose-btn-right\" data-text=\"【口交特化】\">口交</div><div class=\"teapot-pose-btn-right\" data-text=\"【素股特化】\">素股</div><div class=\"teapot-pose-btn-right\" data-text=\"【肛交特化】\">肛交</div>\n<div class=\"teapot-pose-btn-right\" data-text=\"【足交特化】\">足交</div><div class=\"teapot-pose-btn-right\" data-text=\"【露出特化】\">露出</div><div class=\"teapot-pose-btn-right\" data-text=\"【淫语特化】\">淫语</div>\n<div class=\"teapot-pose-btn-right\" data-text=\"【睡奸特化】\">睡奸</div><div class=\"teapot-pose-btn-right\" data-text=\"【调教特化】\">调教</div><div class=\"teapot-pose-btn-right\" data-text=\"【女同特化】\">女同</div>\n</div>\n<div class=\"teapot-pose-group\" style=\"display:none;\">\n<div class=\"teapot-pose-btn-right\" data-text=\"【跳蛋特化】\">跳蛋</div><div class=\"teapot-pose-btn-right\" data-text=\"【震动棒特化】\">震动棒</div><div class=\"teapot-pose-btn-right\" data-text=\"【眼罩/口球/手铐】\">口球</div>\n<div class=\"teapot-pose-btn-right\" data-text=\"【羽毛棒特化】\">羽毛棒</div><div class=\"teapot-pose-btn-right\" data-text=\"【精油特化】\">精油</div><div class=\"teapot-pose-btn-right\" data-text=\"【润滑油特化】\">润滑油</div>\n<div class=\"teapot-pose-btn-right\" data-text=\"【项圈特化】\">项圈</div><div class=\"teapot-pose-btn-right\" data-text=\"【绳艺特化】\">绳艺</div><div class=\"teapot-pose-btn-right\" data-text=\"【鞭子/板子抽打特化】\">鞭子</div>\n<div class=\"teapot-pose-btn-right\" data-text=\"【低温蜡特化】\">低温蜡</div><div class=\"teapot-pose-btn-right\" data-text=\"【乳夹特化】\">乳夹</div><div class=\"teapot-pose-btn-right\" data-text=\"【肛塞特化】\">肛塞</div>\n</div>\n<div class=\"teapot-pose-group\" style=\"display:none;\">\n<div class=\"teapot-pose-btn-right\" data-text=\"【炮机特化】\">炮机</div><div class=\"teapot-pose-btn-right\" data-text=\"【木马特化】\">木马</div><div class=\"teapot-pose-btn-right\" data-text=\"【走绳特化】\">走绳</div>\n<div class=\"teapot-pose-btn-right\" data-text=\"【宠物特化】\">宠物</div><div class=\"teapot-pose-btn-right\" data-text=\"【温酒特化】\">温酒</div><div class=\"teapot-pose-btn-right\" data-text=\"【胶衣特化】\">胶衣</div>\n<div class=\"teapot-pose-btn-right\" data-text=\"【兔女郎特化】\">兔女郎</div><div class=\"teapot-pose-btn-right\" data-text=\"【护士服特化】\">护士服</div><div class=\"teapot-pose-btn-right\" data-text=\"【女仆装特化】\">女仆装</div>\n<div class=\"teapot-pose-btn-right\" data-text=\"【镂空笼装特化】\">Y笼装</div><div class=\"teapot-pose-btn-right\" data-text=\"【裸体围裙特化】\">围裙</div><div class=\"teapot-pose-btn-right\" data-text=\"【开裆特化】\">开裆</div>\n</div>\n</div>\n<div class=\"teapot-pose-clear\" onclick=\"var a=document.querySelector('.chat .chat-bottom .uni-textarea .chat-input-scope textarea');if(a){a.value='';a.dispatchEvent(new Event('input'))}\">清除全部</div>\n</div>\n</div>\n<style>\n.teapot-pose-sidebar-right{position:fixed;right:0;top:50%;transform:translateY(-50%);z-index:9999;filter:drop-shadow(-4px 0 12px rgba(0,0,0,0.5));}\n.teapot-pose-trigger-right{box-sizing:border-box;width:24px;padding:18px 4px;background:linear-gradient(135deg,#1a1a2e,#16213e);border:2px solid #4e4e85;border-right:none;border-radius:10px 0 0 10px;color:#E4D691;cursor:pointer;writing-mode:vertical-rl;text-orientation:mixed;font-size:12px;letter-spacing:3px;text-align:center;}\n.teapot-pose-bubble-right{position:absolute;right:26px;top:calc(50%);transform:translateY(-50%);background:linear-gradient(135deg,#1a1a2e,#16213e);border:2px solid #4e4e85;border-radius:18px;padding:16px;padding-top:48px;width:310px;max-height:520px;display:flex;flex-direction:column;box-sizing:border-box;}\n.teapot-pose-content{flex:1;overflow-y:auto;overflow-x:hidden;padding-right:6px;margin-bottom:12px;min-height:0;scrollbar-width:thin;scrollbar-color:#4e4e85 #16213e;}\n.teapot-pose-content::-webkit-scrollbar{width:6px;}\n.teapot-pose-content::-webkit-scrollbar-track{background:#16213e;border-radius:3px;}\n.teapot-pose-content::-webkit-scrollbar-thumb{background:#4e4e85;border-radius:3px;}\n.teapot-pose-close{position:absolute;top:12px;right:14px;width:32px;height:32px;background:rgba(30,30,50,0.7);border:2px solid #4e4e85;border-radius:50%;color:#F5ED7A;font-size:20px;font-weight:bold;line-height:28px;text-align:center;cursor:pointer;}\n.teapot-pose-close:hover{background:rgba(106,90,205,0.6);}\n.teapot-pose-tabs{display:flex;gap:6px;width:100%;margin-bottom:12px;flex-shrink:0;}\n.teapot-pose-tab{flex:1;padding:10px 2px;background:rgba(30,30,50,0.7);border:2px solid #4e4e85;border-radius:12px;color:#F5ED7A;font-size:13px;font-weight:600;text-align:center;cursor:pointer;}\n.teapot-pose-tab:hover{background:rgba(106,90,205,0.6);}\n.teapot-pose-tab.teapot-tab-active{background:rgba(106,90,205,0.6);color:#E4D691;border-color:#E4D691;}\n.teapot-pose-group{display:flex;flex-wrap:wrap;gap:8px;width:100%;}\n.teapot-pose-btn-right{flex:0 0 calc(33.3333% - 6px);padding:12px 4px;background:rgba(20,20,30,0.6);border:1.5px solid #4e4e85;border-radius:12px;color:#F5ED7A;font-size:13px;font-weight:600;text-align:center;cursor:pointer;box-sizing:border-box;display:flex;align-items:center;justify-content:center;transition:all 0.15s ease;}\n.teapot-pose-btn-right:hover{background:rgba(30,30,50,0.7);border-color:#E4D691;color:#E4D691;}\n.teapot-pose-clear{width:100%;padding:12px;background:rgba(30,30,50,0.7);border:2px solid #4e4e85;border-radius:12px;color:#F5ED7A;font-size:15px;font-weight:700;text-align:center;cursor:pointer;flex-shrink:0;box-sizing:border-box;transition:all 0.15s ease;}\n.teapot-pose-clear:hover{background:rgba(106,90,205,0.6);color:#E4D691;}\n</style>",
