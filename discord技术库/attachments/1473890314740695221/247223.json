{"pageDepth":2,"statusbar":"【音乐】","beginning":"音乐播放。","regex_scripts":[{"id":-1,"replaceString":"<div style=\"position: fixed; top: 50%; right: 15px; transform: translateY(-50%); z-index: 9999999; display: flex; flex-direction: column; align-items: flex-end; font-family: 'Segoe UI', Tahoma, Geneva, sans-serif;\">\n\n  <div id=\"tavern-music-panel-side\" style=\"opacity: 0; pointer-events: none; transition: opacity 0.3s ease; background: linear-gradient(145deg, #3a2318, #24140e); padding: 12px; border-radius: 10px; border: 1px solid #7d4e31; color: #e6d5c3; width: 220px; box-shadow: -4px 4px 15px rgba(0,0,0,0.6); margin-bottom: 12px;\">\n    \n    <div style=\"text-align: center; margin-bottom: 8px; font-size: 13px; color: #d4a373; font-weight: bold; border-bottom: 1px solid #5a3a22; padding-bottom: 4px; user-select: none;\">\n      📜 吟游诗人的曲谱\n    </div>\n    \n    <audio id=\"tavern-player-side\" controls loop style=\"width: 100%; height: 30px; margin-bottom: 8px; border-radius: 4px;\" \n           onloadeddata=\"this.volume=document.getElementById('tavern-vol-side').value\">\n      <source src=\"https://meimoaiimg.com/user/357075/君の銀の庭.mp3\" type=\"audio/mpeg\">\n    </audio>\n\n    <div style=\"display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; font-size: 12px; background-color: #4a3018; padding: 4px 8px; border-radius: 4px; border: 1px solid #8a5a32;\">\n      <span style=\"margin-right: 5px; cursor: default; user-select: none;\" title=\"音量小\">🔉</span>\n      <input id=\"tavern-vol-side\" type=\"range\" min=\"0\" max=\"1\" step=\"0.01\" value=\"0.5\" \n             oninput=\"document.getElementById('tavern-player-side').volume = this.value;\" \n             style=\"flex-grow: 1; cursor: pointer; accent-color: #d4a373;\">\n      <span style=\"margin-left: 5px; cursor: default; user-select: none;\" title=\"音量大\">🔊</span>\n    </div>\n\n    <select onchange=\"document.getElementById('tavern-player-side').src=this.value; document.getElementById('tavern-player-side').play();\" \n            style=\"width: 100%; padding: 5px; background-color: #4a3018; color: #f4e4d4; border: 1px solid #8a5a32; border-radius: 4px; outline: none; cursor: pointer; font-size: 12px; box-sizing: border-box;\">\n      \n      <option value=\"https://meimoaiimg.com/user/357075/君の銀の庭.mp3\">01. 君の銀の庭 (默认)</option>\n      <option value=\"https://meimoaiimg.com/user/357075/君に会えた日.mp3\">02. 君に会えた日</option>\n      <option value=\"https://meimoaiimg.com/user/357075/ワンルームシュガーライフ.mp3\">03. ワンルームシュガーライフ</option>\n      <option value=\"https://meimoaiimg.com/user/357075/高田憂希、寿美菜子 - hectopascal.mp3\">04. 高田憂希、寿美菜子 - hectopascal</option>\n      <option value=\"https://meimoaiimg.com/user/357075/安月名莉子 - 君にふれて.mp3\">05. 安月名莉子 - 君にふれて</option>\n    </select>\n  </div>\n\n  <div onclick=\"var p=document.getElementById('tavern-music-panel-side'); var isOpen = p.style.opacity==='1'; p.style.opacity=isOpen?'0':'1'; p.style.pointerEvents=isOpen?'none':'auto';\" \n       style=\"width: 42px; height: 42px; background: linear-gradient(145deg, #8a5a32, #5a3a22); border: 2px solid #b88655; border-radius: 50%; display: flex; justify-content: center; align-items: center; cursor: pointer; box-shadow: 0 4px 10px rgba(0,0,0,0.5); font-size: 20px; user-select: none; transition: transform 0.2s;\" \n       onmouseover=\"this.style.transform='scale(1.1)'\" \n       onmouseout=\"this.style.transform='scale(1)'\" \n       title=\"点击打开/收起点唱机\">\n    🎶\n  </div>\n</div>\n","scriptName":"音乐","findRegex":"【音乐】"}]}