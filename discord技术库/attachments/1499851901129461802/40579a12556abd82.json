{"pageDepth":2,"statusbar":"","beginning":"<status>\n<div class=\"wf-status-data\" style=\"display:none\">\n<div data-env turn='填入数字' time='填入时间' loc='填入地点'></div>\n\n<div data-char n='角色名' look='外貌描写' wear='衣装描写' pos='姿势描写' chest='雪乳状态' foot='玉足状态' priv='私处状态' rear='臀部状态' love='50' lust='50' mind='内心独白'></div>\n\n<div data-char n='角色名' look='外貌描写' wear='衣装描写' pos='姿势描写' chest='雪乳状态' foot='玉足状态' priv='私处状态' rear='臀部状态' love='50' lust='50' mind='内心独白'></div>\n\n<div data-opt c1='选项一' c2='选项二' c3='选项三'></div>\n</div>\n</status>","regex_scripts":[{"id":-1,"replaceString":"<div class=\"wf-box\" onclick=\"event.stopPropagation()\"><style>@import url('https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@500;700&display=swap');.wf-box{--bg:#f0e6e6;--card-bg:#fdfbfb;--txt:#a56f6f;--border:#d4a5a5;--accent:#d4af37;width:100%;max-width:400px;min-height:300px;background:var(--bg);border:3px double var(--border);border-radius:4px;font-family:'Noto Serif SC',serif;color:var(--txt);display:flex;flex-direction:column;overflow:hidden;margin:10px auto;box-shadow:0 5px 15px rgba(165,111,111,0.2);position:relative}.wf-box *{box-sizing:border-box}.wf-top-bar{padding:8px 12px;border-bottom:2px solid var(--border);display:flex;justify-content:space-between;background:rgba(255,255,255,0.4);font-size:11px;font-weight:bold;flex-shrink:0}.wf-viewport{flex:1;display:flex;overflow-x:auto;overflow-y:visible;scroll-snap-type:x mandatory;scrollbar-width:thin;scrollbar-color:var(--border) transparent;align-items:stretch}.wf-slide{flex:0 0 100%;width:100%;scroll-snap-align:center;padding:10px;display:flex;flex-direction:column;height:auto}.wf-card{background:var(--card-bg);border:1px solid var(--border);padding:8px;box-shadow:3px 3px 0 rgba(212,165,165,0.2);flex:1;display:flex;flex-direction:column;gap:10px}.wf-header{display:flex;justify-content:center;align-items:center;border-bottom:2px double var(--border);padding-bottom:8px;flex-shrink:0}.wf-name{font-size:18px;font-weight:bold;color:#8c5e5e;text-align:center}.wf-group{background:rgba(165,111,111,0.05);border:1px solid var(--border);padding:8px;border-radius:4px;font-size:12px;line-height:1.5}.wf-row{margin-bottom:4px}.wf-lbl{color:var(--accent);font-weight:bold;margin-right:5px}.wf-group.body-parts{display:grid;grid-template-columns:1fr 1fr;gap:8px}.wf-part-item{background:#fff;padding:5px;border:1px dashed var(--border);font-size:11px}.wf-stats-area{margin-top:auto}.wf-bar-row{display:flex;align-items:center;margin-bottom:5px;font-size:11px}.wf-bar-lbl{width:40px;font-weight:bold}.wf-prog-bg{flex:1;height:8px;background:#e0d0d0;border-radius:4px;overflow:hidden;margin:0 8px}.wf-prog-fill{height:100%;border-radius:4px;transition:width 0.5s}.wf-prog-fill.love{background:#efaaaa}.wf-prog-fill.lust{background:#d46a6a}.wf-val{width:30px;text-align:right;font-size:10px}.wf-mind-box{margin-top:10px;padding:8px;background:#fff;border-left:3px solid var(--accent);font-style:italic;font-size:11px;color:#888}.wf-quote{font-size:16px;color:var(--accent);vertical-align:middle;margin-right:4px}.wf-opts{padding:10px;border-top:2px solid var(--border);display:flex;flex-wrap:wrap;gap:8px;justify-content:center;background:rgba(255,255,255,0.4);flex-shrink:0}.wf-btn{background:transparent;border:1px solid var(--txt);color:var(--txt);padding:8px 15px;font-size:12px;cursor:pointer;border-radius:15px;font-family:'Noto Serif SC';transition:0.2s;white-space:normal;line-height:1.2;text-align:center}.wf-btn:hover{background:var(--txt);color:#fff}</style><div class=\"wf-top-bar\"><span class=\"wf-top-time\">--</span><span class=\"wf-top-loc\">--</span><span class=\"wf-top-turn\">Turn: --</span></div><div class=\"wf-viewport\"></div><div class=\"wf-opts\"></div>$1<img src=\"x\" style=\"display:none\" onerror=\"(function(img){var box=img.closest('.wf-box');if(!box)return;var q=function(s,p){return(p||box).querySelector(s)};var attr=function(el,a){return el?el.getAttribute(a)||'':''};var findData=function(sel,cur,all){var db=q('.wf-status-data');if(db){var fd=all?db.querySelectorAll(sel):db.querySelector(sel);if((all&&fd.length>0)||(!all&&fd))return fd}if(cur)return all?[]:null;var bs=document.querySelectorAll('.wf-box'),idx=-1;for(var i=0;i<bs.length;i++){if(bs[i]===box){idx=i;break}}for(var j=idx-1;j>=0;j--){var pd=bs[j].querySelector('.wf-status-data');if(pd){var fd=all?pd.querySelectorAll(sel):pd.querySelector(sel);if((all&&fd.length>0)||(!all&&fd))return fd}}return all?[]:null};var env=findData('div[data-env]',false,false),chars=findData('div[data-char]',false,true),opt=findData('div[data-opt]',true,false);var vp=q('.wf-viewport');if(!vp)return;while(vp.firstChild)vp.removeChild(vp.firstChild);var setT=function(sel,t){var el=q(sel);if(el)el.textContent=t||'--'};if(env){setT('.wf-top-turn','Turn: '+attr(env,'turn'));setT('.wf-top-time',attr(env,'time'));setT('.wf-top-loc',attr(env,'loc'))}var el=function(tg,cs,tx){var e=document.createElement(tg);if(cs)e.className=cs;if(tx)e.textContent=tx;return e};var addR=function(p,lb,vl){var r=el('div','wf-row'),s=el('span','wf-lbl',lb);r.appendChild(s);r.appendChild(document.createTextNode(' '+vl));p.appendChild(r)};for(var i=0;i<chars.length;i++){var c=chars[i],sl=el('div','wf-slide'),cd=el('div','wf-card'),hd=el('div','wf-header');hd.appendChild(el('div','wf-name',attr(c,'n')));cd.appendChild(hd);var g1=el('div','wf-group');addR(g1,'外貌',attr(c,'look'));addR(g1,'衣装',attr(c,'wear'));addR(g1,'姿势',attr(c,'pos'));cd.appendChild(g1);var g2=el('div','wf-group body-parts');g2.appendChild(el('div','wf-part-item',attr(c,'chest')));g2.appendChild(el('div','wf-part-item',attr(c,'foot')));g2.appendChild(el('div','wf-part-item',attr(c,'priv')));g2.appendChild(el('div','wf-part-item',attr(c,'rear')));cd.appendChild(g2);var st=el('div','wf-stats-area'),addB=function(p,lb,vl,cs){var r=el('div','wf-bar-row');r.appendChild(el('span','wf-bar-lbl',lb));var bg=el('div','wf-prog-bg'),fl=el('div','wf-prog-fill '+cs);fl.style.width=(parseInt(vl)||0)+'%';bg.appendChild(fl);r.appendChild(bg);r.appendChild(el('span','wf-val',(parseInt(vl)||0)+'%'));p.appendChild(r)};addB(st,'好感',attr(c,'love'),'love');addB(st,'堕落',attr(c,'lust'),'lust');var mb=el('div','wf-mind-box');mb.appendChild(el('span','wf-quote','💭'));mb.appendChild(document.createTextNode(' '+attr(c,'mind')));st.appendChild(mb);cd.appendChild(st);sl.appendChild(cd);vp.appendChild(sl)}if(opt){var ob=q('.wf-opts');if(ob){while(ob.firstChild)ob.removeChild(ob.firstChild);for(var k=1;k<=5;k++){var ot=attr(opt,'c'+k);if(ot){var btn=el('button','wf-btn',ot);btn.onclick=function(ev){ev.stopPropagation();var t=document.querySelector('.chatMsgTextarea');if(t){var ip=t.querySelector('textarea')||t;ip.value=ip.value+' '+this.textContent;ip.dispatchEvent(new Event('input',{bubbles:true}))}};ob.appendChild(btn)}}}}img.remove()})(this)\"></div>","scriptName":"状态栏","findRegex":"/<status>([\\s\\S]*?)<\\/status>/g"}]}