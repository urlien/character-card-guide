{"pageDepth":null,"statusbar":null,"beginning":"\n【开】\n","regex_scripts":[{"id":-1,"replaceString":"<div class=\"mkt-system\"><style>.mkt-system{display:flex;flex-direction:column;background:#1a140f;border:3px solid #3d2b1f;border-radius:8px;overflow:hidden;font-family:'Microsoft YaHei',serif;margin-top:10px;box-shadow:0 10px 30px rgba(0,0,0,.8);color:#d1b894}.mkt-header-bar{background:linear-gradient(180deg,#4a0f0f 0,#2d0a0a 100%);color:#e0c097;padding:12px;text-align:center;font-weight:700;font-size:1.2em;letter-spacing:4px;border-bottom:2px solid #5c1616;text-shadow:2px 2px 4px #000}.mkt-nav{display:flex;flex-wrap:wrap;background:#28231d;border-bottom:2px solid #3d2b1f;padding:0 5px}.mkt-nav-btn{padding:10px 20px;cursor:pointer;font-size:.9em;color:#8c7861;transition:all .3s;border-right:1px solid #3d2b1f;position:relative;text-align:center}.mkt-nav-btn:hover{background:#3d1212;color:#fff}.mkt-nav-btn.active{background:#4e3b2b;color:#ffca28;font-weight:700}.mkt-nav-btn.active::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;background:#ffca28}.mkt-body{background:url('https://www.transparenttextures.com/patterns/parchment.png'),#1e1a15;min-height:350px;position:relative}.mkt-screen{padding:20px;max-height:500px;overflow-y:auto;scrollbar-width:thin;scrollbar-color:#5c1616 #1a140f}.mkt-page{display:none;animation:mktFade .4s ease-out}.mkt-page.active{display:block}@keyframes mktFade{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}.mkt-section-title{font-size:1.1em;color:#a62b2b;border-bottom:1px double #5c1616;padding-bottom:5px;margin:15px 0 10px}.mkt-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:10px}.mkt-opt{background:#2a241e;border:1px solid #4e3b2b;color:#bfa380;padding:12px 8px;text-align:center;font-size:.85em;cursor:pointer;border-radius:2px}.mkt-opt:hover{border-color:#a62b2b;background:#3d1212;color:#fff}.mkt-opt span{display:block;font-size:.75em;opacity:.6;margin-top:4px}.mkt-report{background:#120e0a;padding:15px;border-top:2px solid #5c1616}.mkt-report-title{color:#8c7861;font-size:.85em;margin-bottom:10px;display:flex;justify-content:space-between}.mkt-report-display{min-height:45px;display:flex;flex-wrap:wrap;gap:8px;margin-bottom:15px}.mkt-tag{background:#2d0a0a;border:1px solid #5c1616;color:#e0c097;padding:4px 12px;font-size:.85em;border-radius:2px;cursor:pointer}.mkt-submit{width:100%;background:linear-gradient(#5c1616,#3d0c0c);color:#e0c097;font-weight:700;border:1px solid #7d1a1a;padding:15px;cursor:pointer;font-size:1.1em;letter-spacing:4px;text-shadow:1px 1px 2px #000}.mkt-submit:hover{filter:brightness(1.2)}</style><div class=\"mkt-header-bar\">† 黑市贸易契约清单 †</div><div class=\"mkt-nav\" id=\"mkt-nav\"></div><div class=\"mkt-body\"><div class=\"mkt-screen\">【1】【2】</div></div><div class=\"mkt-report\"><div class=\"mkt-report-title\"><span>已签署的条款明细</span><span>商会信誉: ★★★</span></div><div class=\"mkt-report-display\" id=\"mkt-display\"></div><button class=\"mkt-submit\" onclick=\"mkt_export()\">签署这份血契</button></div><img src=\"x\" style=\"display:none\" onerror=\"window.mkt_data=[];var P=this.parentNode,D=P.querySelector('#mkt-display'),nav=P.querySelector('#mkt-nav');P.querySelectorAll('.mkt-page').forEach(function(e,t){var a=document.createElement('div');a.className='mkt-nav-btn'+(0==t?' active':''),a.innerText=e.getAttribute('data-tab'),a.onclick=function(){P.querySelectorAll('.mkt-nav-btn').forEach(e=>e.classList.remove('active')),P.querySelectorAll('.mkt-page').forEach(e=>e.classList.remove('active')),a.classList.add('active'),e.classList.add('active')},nav.appendChild(a),0==t&&e.classList.add('active')}),window.mkt_render=function(){D.innerHTML='',window.mkt_data.forEach(function(e,t){var a=document.createElement('div');a.className='mkt-tag',a.innerText=e,a.onclick=function(){window.mkt_data.splice(t,1),mkt_render()},D.appendChild(a)})},window.mkt_push=function(e){e&&(window.mkt_data.push(e),mkt_render())},window.mkt_export=function(){var e=document.querySelector('textarea');e&&window.mkt_data.length&&(e.value+='【黑市贸易契约已签署】: '+window.mkt_data.join('; ')+'。契约已生效，开始经营。',e.dispatchEvent(new Event('input',{bubbles:!0})),window.mkt_data=[],mkt_render(),alert('羊皮纸卷已收好，血契已成。'))},this.remove()\"></div>","scriptName":"开局","findRegex":"【开】"},{"id":-1,"replaceString":"<div class=\"mkt-page\" data-tab=\"我的身份\"><div class=\"mkt-section-title\">商人背景 // Heritage</div><div class=\"mkt-grid\"><div class=\"mkt-opt\" onclick=\"mkt_push('身份: 堕落贵族')\">堕落贵族<span>为了夺回领地</span></div><div class=\"mkt-opt\" onclick=\"mkt_push('身份: 蛮荒猎头')\">蛮荒猎头<span>擅长野外捕捉</span></div><div class=\"mkt-opt\" onclick=\"mkt_push('身份: 异端法师')\">异端法师<span>禁忌的活体实验</span></div></div></div>","scriptName":"【1】","findRegex":"【1】"},{"id":-1,"replaceString":"<div class=\"mkt-page\" data-tab=\"领地选址\"><div class=\"mkt-section-title\">经营据点 // Stronghold</div><div class=\"mkt-grid\"><div class=\"mkt-opt\" onclick=\"mkt_push('据点: 边境地牢')\">边境地牢<span>无法外之地</span></div><div class=\"mkt-opt\" onclick=\"mkt_push('据点: 繁华王都')\">繁华王都<span>高端私人订制</span></div></div></div>","scriptName":"【2】","findRegex":"【2】"}]}